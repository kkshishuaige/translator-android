<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/scrollView"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F0F13"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="🎙️ 同声传译"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="4dp"
            android:text="Gemma 4 本地端到端 · 6种语言互译"
            android:textColor="#888888"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="center"
            android:orientation="horizontal">

            <Spinner
                android:id="@+id/sourceLang"
                android:layout_width="120dp"
                android:layout_height="44dp"
                android:background="@drawable/spinner_bg"
                android:padding="8dp"
                android:textColor="#E0E0E0" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="12dp"
                android:text="→"
                android:textColor="#555555"
                android:textSize="18sp" />

            <Spinner
                android:id="@+id/targetLang"
                android:layout_width="120dp"
                android:layout_height="44dp"
                android:background="@drawable/spinner_bg"
                android:padding="8dp"
                android:textColor="#E0E0E0" />
        </LinearLayout>

        <Button
            android:id="@+id/recordBtn"
            android:layout_width="wrap_content"
            android:layout_height="56dp"
            android:layout_gravity="center"
            android:layout_marginTop="20dp"
            android:backgroundTint="#4A9EFF"
            android:paddingHorizontal="40dp"
            android:text="🎤 开始同传"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/modelStatusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="⏳ 初始化 Gemma 4 模型…"
            android:textColor="#FFA500"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center"
            android:text=""
            android:textColor="#888888"
            android:textSize="13sp" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="#1A1A24"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeColor="#2A2A3A"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📝 语音识别"
                    android:textColor="#4A9EFF"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/transcriptText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:hint="识别文字将显示在此处…"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#555555"
                    android:textSize="20sp"
                    android:lineSpacingExtra="4dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:cardBackgroundColor="#0F1A0F"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeColor="#2A4A2A"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🌍 翻译结果"
                    android:textColor="#4AEF4A"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/translationText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:hint="翻译将显示在此处…"
                    android:textColor="#C0E8C0"
                    android:textColorHint="#3A5A3A"
                    android:textSize="20sp"
                    android:lineSpacingExtra="4dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="📋 历史记录"
            android:textColor="#555555"
            android:textSize="12sp" />

        <LinearLayout
            android:id="@+id/historyLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:orientation="vertical" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:gravity="center"
            android:text="Gemma 4 本地推理 · 完全离线 · 无需网络"
            android:textColor="#444444"
            android:textSize="12sp" />

    </LinearLayout>
</ScrollView>
